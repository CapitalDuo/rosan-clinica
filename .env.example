# ============================================================
# SUPABASE (obrigatório)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only. NUNCA prefixar com NEXT_PUBLIC_ — vazaria pro browser.
# Necessário pra criar usuários da equipe via admin API (feature de Equipe).
# Pegue em: Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# UPSTASH REDIS (opcional — rate limit)
# ============================================================
# Sem essas vars, rate limit fica desativado (fail-open, log warning).
# Provisione via Vercel Marketplace → Upstash Redis (free tier).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
